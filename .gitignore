# ════════════════════════════════════════════════════════════════
#  SentinelAI — .gitignore
# ════════════════════════════════════════════════════════════════

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env/

# ── Environment variables / secrets ─────────────────────────────
.env
.env.*
!.env.example        # keep the example template if you have one

# ── ML model weights (large binary files) ───────────────────────
*.pt
*.pth
*.onnx
*.weights
*.h5
*.pkl
*.joblib

# ── Uploaded video files (user content, not source code) ────────
uploads/
test_videos/

# ── Flask / runtime ─────────────────────────────────────────────
instance/
flask_session/

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/

# ── OS generated ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / editors ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ── Testing ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Type checking ────────────────────────────────────────────────
.mypy_cache/
.dmypy.json

# ── Jupyter ──────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Docker ───────────────────────────────────────────────────────
*.env.docker